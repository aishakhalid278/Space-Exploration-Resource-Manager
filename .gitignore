#ifndef RESOURCEMANAGER_H
#define RESOURCEMANAGER_H

#include <iostream>
#include <string>

class SpaceResource {
private:
    std::string resourceName;
    double quantity;  // Amount in Metric Tons (MT)
    double purity;    // Percentage (0.0 to 1.0)

public:
    // --- Function Overloading ---

    // 1. Default Initialization (Empty Resource)
    SpaceResource() {
        resourceName = "Unknown Mineral";
        quantity = 0.0;
        purity = 0.0;
    }

    // 2. Parameterized Initialization (Specific Resource)
    SpaceResource(std::string name, double qty, double pur) {
        resourceName = name;
        quantity = qty;
        purity = pur;
    }

    // 3. Alternate Input (Initialize from existing with a purity adjustment)
    SpaceResource(const SpaceResource& other, double purityAdjustment) {
        resourceName = other.resourceName + " (Processed)";
        quantity = other.quantity;
        purity = other.purity * purityAdjustment;
    }

    // --- Operator Overloading ---

    // 1. Arithmetic Operator (+): Merge two resource stockpiles
    SpaceResource operator+(const SpaceResource& other) const {
        // Returns a new resource representing the combined weight
        return SpaceResource(this->resourceName, this->quantity + other.quantity, this->purity);
    }

    // 2. Arithmetic Operator (*): Calculate effective yield (Quantity * Purity)
    // Overloading multiplication to scale quantity
    double operator*(double multiplier) const {
        return this->quantity * multiplier;
    }

    // 3. Comparison Operator (<): Check if one resource batch is smaller than another
    bool operator<(const SpaceResource& other) const {
        return (this->quantity < other.quantity);
    }

    // 4. Output Operator (<<): Friend function for mission logs
    friend std::ostream& operator<<(std::ostream& os, const SpaceResource& res) {
        os << "Resource: " << res.resourceName << " | Qty: " << res.quantity 
           << " MT | Purity: " << (res.purity * 100) << "%";
        return os;
    }
};

#endif
